    <br />
    <p>{data["tutorials.categories.dspriki.github.comment.step2"]}<b><code>edit</code></b></p>
    <br />
    <img class="img-tutorial" src='https://cloud-os1gdzoah-hack-club-bot.vercel.app/1image.png'>
    <br />
    <p>{data["tutorials.categories.dspriki.github.comment.step3"]}<b><code>Update comment</code></b></p>
    <br />
    <img class="img-tutorial" src='https://cloud-os1gdzoah-hack-club-bot.vercel.app/2image.png'>
